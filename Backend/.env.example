# Backend Environment Variables Example
# Copy this file to .env and update the values

# Database Configuration
# For SQLite (development):
DATABASE_URL=sqlite:///./spotify_clone.db

# For PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/spotify_clone

# Security Settings
SECRET_KEY=your-super-secret-key-change-this-in-production-with-a-very-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# File Upload
UPLOAD_DIRECTORY=./uploads
MAX_UPLOAD_SIZE=104857600  # 100MB in bytes
ALLOWED_AUDIO_EXTENSIONS=mp3,wav,flac,m4a,aac
ALLOWED_IMAGE_EXTENSIONS=jpg,jpeg,png,gif,webp

# AWS S3 (Optional)
USE_S3=false
AWS_S3_BUCKET=your-bucket-name
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# CORS Settings
CORS_ORIGINS=["http://localhost:5173", "http://127.0.0.1:5173", "http://localhost:3000"]

# Logging
LOG_LEVEL=info

# Development Mode
DEBUG=false
